Bootstrap: docker
From: continuumio/miniconda3:latest

%files
    # Copy project for pip install (pyproject.toml is source of truth)
    ../../pyproject.toml /opt/gradiend/pyproject.toml
    ../../README.md /opt/gradiend/README.md
    ../../gradiend /opt/gradiend/gradiend

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONUNBUFFERED=1
    
    # Conda paths
    export PATH=/opt/conda/bin:$PATH
    export CONDA_PKGS_DIRS=/scratch/$USER/conda-pkgs
    export CONDA_ENVS_DIRS=/scratch/$USER/conda-envs
    
    # Cache directories (will be overridden by bind mounts)
    export HF_HOME=/scratch/$USER/hf
    export TRANSFORMERS_CACHE=/scratch/$USER/hf
    export HUGGINGFACE_HUB_CACHE=/scratch/$USER/hf
    export TORCH_HOME=/scratch/$USER/torch
    export XDG_CACHE_HOME=/scratch/$USER/cache
    export TMPDIR=/scratch/$USER/tmp

%post
    # Update conda
    /opt/conda/bin/conda update -n base -c defaults conda -y
    
    # Install system dependencies if needed
    apt-get update && apt-get install -y \
        git \
        && rm -rf /var/lib/apt/lists/*
    
    # Create conda env with Python, install gradiend from pyproject.toml
    /opt/conda/bin/conda create -n gradiend python=3.10 -y
    /opt/conda/bin/conda run -n gradiend pip install --no-cache-dir -e "/opt/gradiend[recommended,dev]" || true
    
    # Clean up
    /opt/conda/bin/conda clean -afy

%runscript
    # Default: activate conda and run python
    exec /opt/conda/bin/conda run -n gradiend "$@"

%labels
    Author Jonathan Drechsel
    Version 1.0
    Description GRADIEND Test Bench Apptainer Image
